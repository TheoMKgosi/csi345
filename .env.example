# Oracle DB
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=localhost/FREEPDB1

# Service ports
PORTAL_PORT=3000
SARMS_PORT=3001
SARMS_BASE_URL=http://localhost:3001
PORTAL_BASE_URL=http://localhost:3000

# SMTP (optional; if unset, emails are logged as [email:dev])
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@club.local

# Keycloak (IAM)
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=club
KEYCLOAK_ADMIN_CLIENT_ID=portal-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Optional: used when Keycloak sends required-actions emails
KEYCLOAK_ACTIONS_CLIENT_ID=
KEYCLOAK_ACTIONS_REDIRECT_URI=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=bwp
# P100 in smallest unit (e.g. cents/thebe). Default behavior assumes 10000.
STRIPE_UNIT_AMOUNT=10000
